{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "bash .claude/scripts/lint-banned.sh \"$CLAUDE_FILE_PATH\"" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "bash -c 'echo \"$CLAUDE_TOOL_INPUT\" | grep -qi \"\\.tsx\\|\\.ts\" && cd \"$CLAUDE_PROJECT_DIR\" && npx tsc --noEmit --pretty 2>&1 | head -30 || exit 0'" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "echo '[hook] 종료 전 권장: node .claude/scripts/verify.mjs'" }
        ]
      }
    ]
  }
}
